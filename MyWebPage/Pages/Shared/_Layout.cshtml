<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Jerome Gordon-Bock</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="icon" href="~/images/faviconjgb.ico" />
    <link href="https://fonts.googleapis.com/css2?family=Merriweather&family=Montserrat&family=Sacramento&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/navbar.css" />
    
    @RenderSection("Styles", required: false)
    
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg fixed-top" style="background-image: linear-gradient(rgba(154, 231, 231, 0.7), rgba(97, 228, 206, 0.7));">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index" asp-fragment="top">Start</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index" asp-fragment="jag">Profile</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index" asp-fragment="skill">Experience</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index" asp-fragment="contact">Contact</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                Portfolio
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-page="/dices">The Pig Game</a></li>
                                <li><a class="dropdown-item" asp-page="/guessMN">Guess my number</a></li>
                                <li><a class="dropdown-item" asp-page="/memory">Memory</a></li>
                                <li><a class="dropdown-item" href="https://bockarns.github.io/Golfklubb-Centar/" target="_blank">Golf Club Centar (Swedish)</a></li>
                                <li><a class="dropdown-item" href="https://github.com/Bockarns" target="_blank">More on my GitHub here!</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                CV / Resume
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-page="/CVEnglish">English</a></li>
                                <li><a class="dropdown-item" asp-page="/CVSwedish">Swedish</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="bottom-container">
        <a class="footer-link" href="https://www.linkedin.com/in/jerome-gordon-bock/">LinkedIn</a>
        <a class="footer-link" href="https://twitter.com/Bockarn">Twitter</a>
        <a class="footer-link" href="https://www.facebook.com/jeromebock">Facebook</a>
        <a class="footer-link" href="https://github.com/Bockarns">Github</a>
        <p class="copyright">© 2026 Jerome Gordon-Bock.</p>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>