@page
@model IndexModel
@{
    ViewData["Title"] = "Jerome Gordon-Bock";
}

@section Styles {
<link rel="stylesheet" href="~/css/index.css" asp-append-version="true" />
}
<section class="top-container" id="top">
    <img class="cloud-top cloud" src="images/cloud.png" alt="cloud-img" />
    <div class="welcome">
        <h1 class="iam">I'm Jerome.</h1>
        <h2>a <span class="pro">pro</span>grammer</h2>
        <h4>in development.</h4>
    </div>
    <img class="cloud-bottom cloud" src="images/cloud.png" alt="cloud-img" />
    <img class="mountain-img" src="images/mountain.png" alt="mountain-img" />
    <img class="sun-img"
         src="./images/Sun250.png"
         alt="Sun behind mountain" />
</section>

<section class="middle-container" id="jag">
    <div class="profile">
        <img src="images/Jerome.png" alt="Jerome Gordon-Bock" />
        <h2>Hello</h2>
        <p class="presentation">My name is Jerome Gordon-Bock</p>
        <p>
            I'm very passionate about web development and enjoy working across the
            full stack, from frontend design to backend logic and databases with
            C# and SQL.
        </p>
        <p>
            I enjoy turning ideas into real, functional systems and solving
            problems through code.
        </p>
        <p>
            I'm currently studying to become a web developer, and I'm highly
            motivated to keep growing my skills and contributing to real projects.
        </p>
    </div>
    <div class="break-line-home" id="skill"></div>
    <div class="skills">
        <h2>My Experience</h2>
        <div class="skill-row">
            <img class="coding-img" src="images/coding.png" alt="coding" />
            <h3 class="left-h3">Web development</h3>
            <p>
                Starting August 2025 I'm heading back to the schoolbench at
                <a href="https://www.tucsweden.se/utbildning/program/webbutvecklare-distans-jonkoping/">TUC sweden Jönköping</a>, with their vocational education webdevelopment program.
            </p>
        </div>
        <div class="skill-row">
            <img class="it-tech-img" src="images/van.png" alt="van" />
            <h3 class="right-h3">IT Technician</h3>
            <p>
                between 2023 to currently I've been working as a IT Technician for
                homes and businesses, but started to re-educate myself
                to webdeveloper fall of 2025.
            </p>
        </div>

        <div class="skill-row">
            <img class="coding-img" src="images/coding.png" alt="coding" />
            <h3 class="left-h3">Web Development</h3>
            <p>
                I've always loved computers and games, and my wife bought me a
                online course at
                <a href="https://www.udemy.com/course/the-complete-web-development-bootcamp/">Udemy</a>
                for my birthday, and I loved it! But unfortunately I never got the
                time to finish it.
            </p>
        </div>

        <div class="skill-row">
            <img class="lock-img" src="images/keys.png" alt="Keys" />
            <h3 class="right-h3">Locksmith</h3>
            <p>
                From 2008 until 2022 I've been working as a Journeyman Certified
                locksmith, but started looking for a new path in my life around
                2022.
            </p>
        </div>
    </div>

    <div class="break-line-home" id="contact"></div>

    <div class="contact-me">
        <h2>Get In Touch</h2>
        <h3>Email</h3>
        <p class="contact-message">
            To get in contact with me, click the button below to send a email to
            me.
        </p>
        <a class="btn-main" href="mailto:jerome.bock@gmail.com">CONTACT ME</a>
    </div>
</section>
